{
  "name": "@eoussama/temmejs",
  "type": "module",
  "version": "1.0.7",
  "packageManager": "pnpm@11.4.0",
  "description": "Temme (or Emmet in reverse) is to javascript what Emmet is to HTML and CSS, with no doubts, Emmet saved us from the headache of working with HTML and CSS, and now, Temme is doing Javascript the same favour too.",
  "author": "EOussama",
  "license": "MIT",
  "homepage": "https://github.com/EOussama/temmejs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EOussama/temmejs.git"
  },
  "bugs": {
    "url": "https://github.com/EOussama/temmejs/issues"
  },
  "keywords": [
    "typescript",
    "javascript",
    "javascript-library",
    "dom",
    "emmet"
  ],
  "exports": {
    ".": {
      "types": "./dist/temme.d.ts",
      "import": "./dist/temme.js",
      "require": "./dist/temme.cjs"
    }
  },
  "main": "./dist/temme.cjs",
  "module": "./dist/temme.js",
  "types": "./dist/temme.d.ts",
  "files": [
    "dist"
  ],
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "clean": "rm -rf dist build",
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest": "tsc --project tsconfig.test.json",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm dx lint",
    "lint:fix": "pnpm dx lint --fix",
    "build:docs": "rm -rf docs/assets/js/lib && mkdir -p docs/assets/js/lib && esbuild src/temme.ts --bundle --format=esm --minify --sourcemap --outfile=docs/assets/js/lib/temme.js --platform=browser --target=es2020",
    "prod": "pnpm clean && pnpm build && pnpm build:docs"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@eoussama/core": "^0.0.4"
  },
  "devDependencies": {
    "@eoussama/dx": "^0.0.4",
    "@types/node": "^14.11.8",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
